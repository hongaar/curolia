{
  "name": "curolia",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npx turbo run lint typecheck test build",
    "version:resolve": "tsx scripts/resolve-app-version.ts",
    "version:sync-native": "tsx scripts/sync-native-version.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "turbo": "2.9.8",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@vercel/node": {
      "typescript5": "$typescript"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,json,css,scss,html,yml,yaml,md,mdx}": "prettier --write"
  }
}
