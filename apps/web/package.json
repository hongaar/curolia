{
  "name": "@curolia/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "plugins:sync": "node scripts/generate-plugin-registry.mjs",
    "licenses:generate": "node scripts/generate-npm-licenses.mjs",
    "codegen": "npm run plugins:sync && npm run licenses:generate",
    "dev": "vite",
    "build": "tsc -b && vite build --ssrManifest && vite build --ssr src/entry-server.tsx --outDir dist-ssr && node scripts/generate-sitemap.mjs && node scripts/stage-vercel-ssr.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "ssr:preview": "node scripts/ssr-preview.mjs",
    "ssr:debug": "node scripts/ssr-debug.mjs",
    "ssr:smoke": "node scripts/ssr-smoke.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "vercel:pull:production": "vercel pull --yes --environment=production ${VERCEL_TOKEN:+--token=$VERCEL_TOKEN}",
    "vercel:build:production": "vercel build --prod ${VERCEL_TOKEN:+--token=$VERCEL_TOKEN}",
    "vercel:deploy:production": "vercel deploy --prebuilt --prod ${VERCEL_TOKEN:+--token=$VERCEL_TOKEN}"
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "8.3.4",
    "@capacitor/device": "8.0.2",
    "@capacitor/geolocation": "8.2.0",
    "@capacitor/push-notifications": "8.1.1",
    "@curolia/plugin-comments": "file:../../packages/plugins/comments",
    "@curolia/plugin-contract": "file:../../packages/plugin-contract",
    "@curolia/plugin-directions": "file:../../packages/plugins/directions",
    "@curolia/plugin-google-maps-saved-lists": "file:../../packages/plugins/google-maps-saved-lists",
    "@curolia/plugin-google-photos": "file:../../packages/plugins/google-photos",
    "@curolia/plugin-ical": "file:../../packages/plugins/ical",
    "@curolia/plugin-lastfm": "file:../../packages/plugins/lastfm",
    "@curolia/plugin-open-meteo": "file:../../packages/plugins/open-meteo",
    "@curolia/plugin-poi": "file:../../packages/plugins/poi",
    "@curolia/plugin-polarsteps": "file:../../packages/plugins/polarsteps",
    "@curolia/plugin-reactions": "file:../../packages/plugins/reactions",
    "@curolia/plugin-spotify": "file:../../packages/plugins/spotify",
    "@curolia/plugin-wikidata": "file:../../packages/plugins/wikidata",
    "@curolia/services": "file:../../packages/services",
    "@curolia/site": "file:../../packages/site",
    "@curolia/ui": "file:../../packages/ui",
    "@floating-ui/dom": "1.7.6",
    "@fontsource-variable/geist": "5.2.8",
    "@sentry/react": "10.57.0",
    "@supabase/supabase-js": "2.105.1",
    "@tanstack/react-query": "5.100.9",
    "clsx": "2.1.1",
    "frimousse": "0.3.0",
    "lucide-react": "1.17.0",
    "maplibre-gl": "5.24.0",
    "next-themes": "0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "7.14.2",
    "shadcn": "4.6.0",
    "sonner": "2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/node": "5.5.14",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "26.1.0",
    "license-checker": "25.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vercel": "48.12.1",
    "vite": "8.0.10",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "3.2.4"
  }
}
