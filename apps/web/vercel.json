{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "installCommand": "npm ci --prefix ../..",
  "buildCommand": "cd ../.. && npx turbo run codegen build --filter=@curolia/web",
  "outputDirectory": "dist",
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "{dist,dist-ssr}/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/ssr" }]
}
