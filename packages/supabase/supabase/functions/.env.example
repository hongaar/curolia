# Copy to `.env` in this directory (never commit `.env`).
# Loaded automatically by `supabase functions serve` / `npm run functions:start -w @curolia/supabase`.
#
# Push notifications (push-dispatch)
PUSH_DISPATCH_SECRET=
FCM_SERVER_KEY=

# Plugin sync job dispatch (plugin-sync-dispatch → per-plugin *-dispatch workers)
# Generate: openssl rand -base64 32
# Same pattern as PUSH_DISPATCH_SECRET — not issued by Supabase; you create and store it.
PLUGIN_SYNC_DISPATCH_SECRET=
#
# pg_cron reads the same secret from private.worker_config.plugin_sync_dispatch_secret.
# Local: npm run db:sync-dispatch-secret -w @curolia/supabase (reads this file).
# Production: set the Edge Function secret in Supabase, then copy it into
# private.worker_config manually (see README → Plugin sync jobs).

# Plugin OAuth (plugin-oauth) — shared by Google Photos, Spotify, etc.
# Generate key: openssl rand -base64 32
# Must be identical for every function that reads tokens; changing it breaks decryption until users unlink + re-link.
PLUGIN_OAUTH_ENCRYPTION_KEY=

# Google OAuth (Google Photos + Google Maps saved lists; plugin-oauth + plugin Edge functions)
# Enable Data Portability API in Google Cloud for google_maps_saved_lists.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps saved lists — coordinate lookup during download (google-maps-saved-lists)
# SERVER key only: Application restriction = IP addresses (prod) or None/your IP (local dev).
# Never use HTTP referrer restrictions — those are browser keys and fail from Edge Functions.
# API restrictions: Places API + Places API (New). Keep this key out of apps/web (server env only).
# GOOGLE_MAPS_API_KEY is accepted as an alias for GOOGLE_PLACES_API_KEY.
GOOGLE_PLACES_API_KEY=
# GEOAPIFY_API_KEY=   # optional geocoding when a place is not found via Places (not a substitute for a bad Google key)

# Optional emoji suggestion LLM fallback (Edge Functions using @curolia/services/emoji)
# EMOJI_LLM_API_KEY=
# EMOJI_LLM_PROVIDER=openai
# EMOJI_LLM_MODEL=gpt-4o-mini
# EMOJI_LLM_BASE_URL=https://api.openai.com/v1/chat/completions

# Spotify (plugin-oauth + spotify Edge function)
# Both required: spotify uses client credentials to resolve track/playlist metadata.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API (lastfm Edge function — user.getRecentTracks)
LASTFM_API_KEY=

PUBLIC_APP_ORIGIN=http://127.0.0.1:5173
# Optional: override OAuth redirect_uri if defaults are wrong (tunnel, non-default API port).
# Local default is rewritten from internal http://kong:8000 → http://127.0.0.1:54321 when hostname is kong.
# PLUGIN_OAUTH_CALLBACK_URL=http://127.0.0.1:54321/functions/v1/plugin-oauth?action=callback
