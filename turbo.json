{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@curolia/brand#codegen": {
      "cache": false
    },
    "@curolia/web#codegen": {
      "dependsOn": ["@curolia/brand#codegen"],
      "cache": false
    },
    "@curolia/web#build": {
      "dependsOn": ["codegen"],
      "outputs": ["dist/**", "dist-ssr/**"],
      "env": ["APP_VERSION", "VERCEL"]
    },
    "@curolia/web#lint": {
      "dependsOn": ["codegen"]
    },
    "@curolia/web#typecheck": {
      "dependsOn": ["codegen"]
    },
    "@curolia/web#test": {
      "dependsOn": ["codegen"]
    },
    "@curolia/web#ssr:smoke": {
      "dependsOn": ["@curolia/web#build"]
    },
    "@curolia/e2e#e2e": {
      "cache": false,
      "env": [
        "CI",
        "E2E_BASE_URL",
        "E2E_ENFORCE_BASELINE",
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY",
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_PUBLISHABLE_KEY"
      ]
    },
    "@curolia/supabase#stack": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/web#dev": {
      "dependsOn": ["@curolia/supabase#stack"],
      "cache": false,
      "persistent": true
    },
    "@curolia/supabase#dev": {
      "dependsOn": ["@curolia/supabase#stack"],
      "cache": false,
      "persistent": true
    },
    "@curolia/ui#dev": {
      "cache": false,
      "persistent": true
    },
    "@curolia/site#dev": {
      "cache": false,
      "persistent": true
    },
    "@curolia/site#typecheck": {
      "outputs": []
    },
    "@curolia/ui#typecheck": {
      "outputs": []
    },
    "@curolia/ui#test": {
      "outputs": []
    },
    "@curolia/site#test": {
      "outputs": []
    },
    "@curolia/brand#generate:native": {
      "cache": false
    },
    "@curolia/supabase#functions:sync": {
      "cache": false
    },
    "@curolia/supabase#test": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/plugin-poi#test": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/plugin-wikidata#test": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/plugin-flickr#test": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/plugin-commons#test": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/plugin-google-maps-saved-lists#typecheck": {
      "dependsOn": ["@curolia/supabase#functions:sync"],
      "cache": false
    },
    "@curolia/mobile#sync": {
      "dependsOn": ["@curolia/brand#generate:native", "@curolia/web#build"],
      "cache": false
    }
  }
}
